---
import ThemeSwitcher from "./ThemeSwitcher.astro";
const currentPath = Astro.url.pathname;

const path = currentPath === "/" ? "/" : currentPath.replace(/\/$/, "");

const navLinks = [
  { href: "/", label: "home", active: path === "/" },
  { href: "/start-here", label: "start here", active: path === "/start-here" },
  { href: "/blog", label: "blog", active: path === "/blog" || path.startsWith("/blog/") },
  { href: "/projects", label: "projects", active: path === "/projects" },
  { href: "/about", label: "about", active: path === "/about" },
];

const socialLinks = [
  { label: "github",   href: "https://github.com/sudomakevibe" },
  { label: "x",        href: "https://x.com/sudomakevibe" },
  { label: "linkedin", href: "https://www.linkedin.com/in/farooqganai/" },
  { label: "mastodon", href: "https://mastodon.social/@sudomakevibe", rel: "me" },
  { label: "reddit",   href: "https://reddit.com/u/sudomakevibe" },
  { label: "dev.to",   href: "https://dev.to/sudomakevibe" },
  { label: "rss",      href: "/rss.xml" },
  // --- Uncomment when ready ---
  // { label: "linkedin", href: "https://linkedin.com/in/sudomakevibe" },
  // { label: "discord",  href: "https://discord.gg/sudomakevibe" },
  // { label: "hashnode", href: "https://sudomakevibe.hashnode.dev" },
  // { label: "hackster", href: "https://hackster.io/sudomakevibe" },
  // { label: "hackaday", href: "https://hackaday.io/sudomakevibe" },
];
---

<footer class="border-t py-8 mt-16" style="border-color: var(--border);">
  <div class="max-w-6xl mx-auto px-4">

    <!-- Nav links -->
    <div class="flex flex-wrap justify-between items-center gap-4 mb-6">
      <div class="flex flex-wrap gap-4 md:gap-6 text-sm font-mono">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class="footer-link"
            data-active={link.active ? "true" : "false"}
            style={`color: ${link.active ? "var(--accent)" : "var(--text-secondary)"}; text-decoration: none;`}
          >
            {link.label}
          </a>
        ))}
      </div>
      <div class="flex items-center gap-2">
        <span class="text-xs font-mono" style="color: var(--accent);">palettes:</span>
        <ThemeSwitcher />
      </div>
    </div>

    <!-- Social links — text only, terminal native -->
    <div class="flex flex-wrap justify-center gap-2 items-center font-mono text-sm mb-6">
      {socialLinks.map((social, i) => (
        <>
          <a
            href={social.href}
            target={social.href.startsWith("http") ? "_blank" : undefined}
            rel={social.href.startsWith("http") ? `noopener noreferrer${social.rel ? " " + social.rel : ""}` : undefined}
            class="social-link"
            style="color: var(--text-secondary); text-decoration: none;"
          >
            {social.label}
          </a>
          {i < socialLinks.length - 1 && (
            <span style="color: var(--border);">·</span>
          )}
        </>
      ))}
    </div>

    <!-- Copyright -->
    <div
      class="text-xs font-mono"
      style="color: var(--text-secondary); opacity: 0.5;"
    >
      <p>© {new Date().getFullYear()} sudo make vibe</p>
    </div>

  </div>
</footer>

<style>
  .footer-link:hover {
    color: var(--accent) !important;
  }
  .footer-link[data-active="true"] {
    color: var(--accent) !important;
  }
  .social-link:hover {
    color: var(--accent) !important;
  }
</style>
