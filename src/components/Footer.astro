---
import ThemeSwitcher from "./ThemeSwitcher.astro";
const currentPath = Astro.url.pathname;

const path = currentPath === "/" ? "/" : currentPath.replace(/\/$/, "");

const navLinks = [
  { href: "/", label: "home", active: path === "/" },
  { href: "/start-here", label: "start here", active: path === "/start-here" },
  { href: "/blog", label: "blog", active: path === "/blog" || path.startsWith("/blog/") },
  { href: "/projects", label: "projects", active: path === "/projects" },
  { href: "/about", label: "about", active: path === "/about" },
];

const socialLinks = [
  { label: "github",   href: "https://github.com/sudomakevibe" },
  { label: "x",        href: "https://x.com/sudomakevibe" },
  { label: "linkedin", href: "https://www.linkedin.com/in/farooqganai/" },
  { label: "mastodon", href: "https://mastodon.social/@sudomakevibe", rel: "me" },
  { label: "reddit",   href: "https://reddit.com/u/sudomakevibe" },
  { label: "dev.to",   href: "https://dev.to/sudomakevibe" },
  { label: "rss",      href: "/rss.xml" },
];
---

<footer class="mt-16 py-10 px-4" style="border-top: 1px solid var(--border);">
  <div class="max-w-6xl mx-auto">

    <!-- Nav + Palette -->
    <div class="flex flex-wrap justify-between items-center gap-4 mb-8">
      <div class="flex flex-wrap gap-6 text-sm font-mono">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class="footer-nav-link"
            style={`color: ${link.active ? "var(--accent)" : "var(--text-secondary)"}; text-decoration: none;`}
          >
            {link.label}
          </a>
        ))}
      </div>
      <div class="flex items-center gap-2">
        <span class="text-xs font-mono" style="color: var(--accent);">palettes:</span>
        <ThemeSwitcher />
      </div>
    </div>

    <!-- Social links -->
    <div
      class="flex flex-wrap justify-center gap-2 items-center font-mono text-sm py-5 mb-6"
      style="border-top: 0.5px solid var(--border); border-bottom: 0.5px solid var(--border);"
    >
      {socialLinks.map((social, i) => (
        <>
          <a
            href={social.href}
            target={social.href.startsWith("http") ? "_blank" : undefined}
            rel={social.href.startsWith("http") ? `noopener noreferrer${social.rel ? " " + social.rel : ""}` : undefined}
            class="footer-social-link"
            style="color: var(--text-secondary); text-decoration: none;"
          >
            {social.label}
          </a>
          {i < socialLinks.length - 1 && (
            <span style="color: var(--border);">·</span>
          )}
        </>
      ))}
    </div>

    <!-- Copyright + License -->
    <div class="flex flex-wrap justify-between items-center gap-2 text-xs font-mono">
      <div>
        <span style="color: var(--text-secondary);">© {new Date().getFullYear()} </span>
        <span style="color: var(--accent);">Farooq Ganai</span>
        <span style="color: var(--text-secondary);"> · sudomakevibe.com</span>
      </div>
      <div class="flex items-center gap-2">
        <span style="color: var(--text-secondary);">Code: </span>
        <a
          href="https://github.com/sudomakevibe/sudomakevibe/blob/main/LICENSE"
          target="_blank"
          rel="noopener noreferrer"
          style="color: var(--accent); text-decoration: none;"
          class="footer-license-link"
        >MIT License</a>
        <span style="color: var(--border);">·</span>
        <span style="color: var(--text-secondary);">Content: </span>
        <span style="color: var(--accent);">All Rights Reserved</span>
      </div>
    </div>

  </div>
</footer>

<style>
  .footer-nav-link:hover {
    color: var(--accent) !important;
  }
  .footer-social-link:hover {
    color: var(--accent) !important;
  }
  .footer-license-link:hover {
    text-decoration: underline !important;
  }
</style>
