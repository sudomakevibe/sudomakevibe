---
const FORM_ID = "9282740";
const API_KEY = import.meta.env.PUBLIC_CONVERTKIT_API_KEY;
---

<form
  class="flex flex-col sm:flex-row justify-center gap-3"
  id="newsletter-form"
>
  <input
    type="email"
    id="email_address"
    name="email_address"
    placeholder="you@example.com"
    class="rounded-lg px-4 py-3 w-72 focus:outline-none font-mono text-sm"
    style="background-color: var(--bg-primary); border: 1px solid var(--border); color: var(--text-primary);"
    required
  />
  <button
    type="submit"
    class="px-6 py-3 rounded-lg font-semibold transition text-sm inline-flex items-center justify-center gap-2"
    style="background-color: var(--accent); color: var(--bg-primary);"
  >
    Subscribe
    <span style="font-size: 1.1em; line-height: 1;">→</span>
  </button>
</form>

<div
  id="success-message"
  class="hidden mt-4 text-sm text-center"
  style="color: var(--accent);"
>
  ✓ Success! Check your email to confirm your subscription.
</div>

<div
  id="error-message"
  class="hidden mt-4 text-sm text-center"
  style="color: #ef4444;"
>
  ✗ Something went wrong. Please try again.
</div>

<script>
  const form = document.getElementById("newsletter-form");
  const successMsg = document.getElementById("success-message");
  const errorMsg = document.getElementById("error-message");
  const FORM_ID = "9282740";
  const API_KEY = "${API_KEY}";

  form.addEventListener("submit", async (e) => {
    e.preventDefault();

    // Hide any existing messages
    successMsg.classList.add("hidden");
    errorMsg.classList.add("hidden");

    const email = document.getElementById("email_address").value;

    try {
      const response = await fetch(
        `https://api.convertkit.com/v3/forms/${FORM_ID}/subscribe`,
        {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
          },
          body: JSON.stringify({
            email_address: email,
            api_key: API_KEY,
          }),
        },
      );

      const data = await response.json();

      if (response.ok) {
        successMsg.classList.remove("hidden");
        form.reset();
        setTimeout(() => {
          successMsg.classList.add("hidden");
        }, 5000);
      } else {
        console.error("ConvertKit error:", data);
        errorMsg.classList.remove("hidden");
        setTimeout(() => {
          errorMsg.classList.add("hidden");
        }, 5000);
      }
    } catch (error) {
      console.error("Error:", error);
      errorMsg.classList.remove("hidden");
      setTimeout(() => {
        errorMsg.classList.add("hidden");
      }, 5000);
    }
  });
</script>
