---
const FORM_ENDPOINT = "https://app.kit.com/forms/2494968262/subscriptions";
---

<form
  action={FORM_ENDPOINT}
  method="post"
  class="flex flex-col sm:flex-row justify-center gap-3"
  id="newsletter-form"
>
  <input
    type="email"
    name="email_address"
    placeholder="you@example.com"
    class="rounded-lg px-4 py-3 w-72 focus:outline-none font-mono text-sm"
    style="background-color: var(--bg-primary); border: 1px solid var(--border); color: var(--text-primary);"
    required
  />
  <input type="hidden" name="form_id" value="2494968262" />
  <input type="hidden" name="tags" value="website" />
  <button
    type="submit"
    class="px-6 py-3 rounded-lg font-semibold transition text-sm inline-flex items-center justify-center gap-2"
    style="background-color: var(--accent); color: var(--bg-primary);"
  >
    Subscribe
    <span style="font-size: 1.1em; line-height: 1;">→</span>
  </button>
</form>

<div
  id="success-message"
  class="hidden mt-4 text-sm text-center"
  style="color: var(--accent);"
>
  ✓ Success! Check your email to confirm your subscription.
</div>

<div
  id="error-message"
  class="hidden mt-4 text-sm text-center"
  style="color: #ef4444;"
>
  ✗ Something went wrong. Please try again.
</div>

<script>
  const form = document.getElementById("newsletter-form");
  const successMsg = document.getElementById("success-message");
  const errorMsg = document.getElementById("error-message");

  form.addEventListener("submit", async (e) => {
    e.preventDefault();

    successMsg.classList.add("hidden");
    errorMsg.classList.add("hidden");

    const formData = new FormData(form);

    try {
      const response = await fetch(form.action, {
        method: "POST",
        body: formData,
        headers: { Accept: "application/json" },
      });

      const result = await response.json();

      if (response.ok) {
        successMsg.classList.remove("hidden");
        form.reset();
        setTimeout(() => {
          successMsg.classList.add("hidden");
        }, 5000);
      } else {
        console.error("ConvertKit error:", result);
        throw new Error(result.error || "Submission failed");
      }
    } catch (error) {
      console.error("Error:", error);
      errorMsg.classList.remove("hidden");
      setTimeout(() => {
        errorMsg.classList.add("hidden");
      }, 5000);
    }
  });
</script>
