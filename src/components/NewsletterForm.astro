---
// TEMPORARY: Direct API key for no-pop-up experience
// Replace with your actual V4 API key
const API_KEY = "kit_206f411e36ccbc8eee4797412dfc9c62";
const FORM_ID = "9259710";
const API_URL = "https://api.kit.com/v4";
---

<form
  class="flex flex-col sm:flex-row justify-center gap-3"
  id="newsletter-form"
>
  <input
    type="email"
    id="email_address"
    name="email_address"
    placeholder="you@example.com"
    class="rounded-lg px-4 py-3 w-72 focus:outline-none font-mono text-sm"
    style="background-color: var(--bg-primary); border: 1px solid var(--border); color: var(--text-primary);"
    required
  />
  <button
    type="submit"
    class="px-6 py-3 rounded-lg font-semibold transition text-sm inline-flex items-center justify-center gap-2"
    style="background-color: var(--accent); color: var(--bg-primary);"
  >
    Subscribe
    <span style="font-size: 1.1em; line-height: 1;">→</span>
  </button>
</form>

<div
  id="success-message"
  class="hidden mt-4 text-sm text-center"
  style="color: var(--accent);"
>
  ✓ Success! Check your email to confirm your subscription.
</div>

<div
  id="error-message"
  class="hidden mt-4 text-sm text-center"
  style="color: #ef4444;"
>
  ✗ Something went wrong. Please try again.
</div>

<script>
  const form = document.getElementById("newsletter-form");
  const successMsg = document.getElementById("success-message");
  const errorMsg = document.getElementById("error-message");
  const FORM_ID = "9259710";
  const API_KEY = "kit_206f411e36ccbc8eee4797412dfc9c62";
  const API_URL = "https://api.kit.com/v4";

  form.addEventListener("submit", async (e) => {
    e.preventDefault();

    successMsg.classList.add("hidden");
    errorMsg.classList.add("hidden");

    const email = document.getElementById("email_address").value;

    try {
      // Step 1: Create subscriber as 'inactive'
      const createResponse = await fetch(`${API_URL}/subscribers`, {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
          "X-Kit-Api-Key": API_KEY,
        },
        body: JSON.stringify({
          email_address: email,
          state: "inactive",
        }),
      });

      if (!createResponse.ok) {
        const errorData = await createResponse.json();
        throw new Error(errorData.errors?.[0] || "Failed to create subscriber");
      }

      // Step 2: Add subscriber to form (this triggers confirmation email)
      const formResponse = await fetch(
        `${API_URL}/forms/${FORM_ID}/subscribers`,
        {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
            "X-Kit-Api-Key": API_KEY,
          },
          body: JSON.stringify({
            email_address: email,
          }),
        },
      );

      if (formResponse.ok) {
        successMsg.classList.remove("hidden");
        form.reset();
        setTimeout(() => successMsg.classList.add("hidden"), 5000);
      } else {
        const errorData = await formResponse.json();
        throw new Error(errorData.errors?.[0] || "Failed to add to form");
      }
    } catch (error) {
      console.error("ConvertKit error:", error);
      errorMsg.classList.remove("hidden");
      setTimeout(() => errorMsg.classList.add("hidden"), 5000);
    }
  });
</script>
