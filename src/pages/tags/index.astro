---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const posts = await getCollection("posts");
const published = posts.filter((p) => !p.data.draft);

// Build a map of tag → count, sorted by count descending
const tagMap = new Map<string, number>();
for (const post of published) {
  for (const tag of post.data.tags) {
    tagMap.set(tag, (tagMap.get(tag) ?? 0) + 1);
  }
}
const sortedTags = [...tagMap.entries()].sort((a, b) => b[1] - a[1]);
---

<BaseLayout
  title="Tags | sudo make vibe"
  description="Browse all topics covered on sudo make vibe — Linux, Kubernetes, Raspberry Pi, AI, Cybersecurity, and more."
>
  <main class="max-w-4xl mx-auto px-4 py-12">
    <div class="mb-12">
      <h1 class="text-4xl font-bold mb-3" style="color: var(--accent);">/tags</h1>
      <p style="color: var(--text-secondary);">Browse posts by topic.</p>
    </div>

    {sortedTags.length === 0 ? (
      <p style="color: var(--text-secondary);">No tags yet. Check back after the first posts are published.</p>
    ) : (
      <div class="flex flex-wrap gap-3">
        {sortedTags.map(([tag, count]) => (
          <a
            href={`/tags/${tag}`}
            style="text-decoration: none;"
          >
            <span
              class="inline-flex items-center gap-2 px-4 py-2 rounded-full text-sm font-mono transition-all"
              style="background-color: var(--bg-card); border: 1px solid var(--border); color: var(--text-secondary);"
              onmouseover="this.style.borderColor='var(--accent)'; this.style.color='var(--accent)';"
              onmouseout="this.style.borderColor='var(--border)'; this.style.color='var(--text-secondary)';"
            >
              <span style="color: var(--accent);">#</span>{tag}
              <span
                class="text-xs px-1.5 py-0.5 rounded-full font-mono"
                style="background-color: var(--bg-secondary); color: var(--text-secondary);"
              >
                {count}
              </span>
            </span>
          </a>
        ))}
      </div>
    )}

    <!-- Also link to tags from the blog nav -->
    <div class="mt-12 pt-8" style="border-top: 1px solid var(--border);">
      <a
        href="/blog"
        class="text-sm font-mono"
        style="color: var(--text-secondary); text-decoration: none;"
      >
        ← back to all posts
      </a>
    </div>
  </main>
</BaseLayout>
