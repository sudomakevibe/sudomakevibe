---
import BaseLayout from "../layouts/BaseLayout.astro";
import NewsletterForm from "../components/NewsletterForm.astro";
import BlogCard from "../components/BlogCard.astro";
import { getCollection } from "astro:content";

function calculateReadingTime(text: string): string {
  const wordsPerMinute = 200;
  const words = text.trim().split(/\s+/).length;
  const minutes = Math.ceil(words / wordsPerMinute);
  return `${minutes} min read`;
}

const posts = await getCollection("posts");
const latestPosts = await Promise.all(
  posts
    .filter((post) => !post.data.draft)
    .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
    .slice(0, 2)
    .map(async (post) => {
      const readingTime = post.data.readingTime || calculateReadingTime(post.body);
      return { ...post, readingTime };
    })
);

const projects = [
  {
    title: "sudo make vibe",
    subtitle: "Building sudomakevibe.com from idea to production",
    status: "active",
    tags: ["astro", "vercel", "tailwind", "open-source", "spaceship", "vscode", "git", "github"],
    slug: null,
  },
  {
    title: "sudo make homelab",
    subtitle: "The physical and logical foundation everything runs on",
    status: "in-progress",
    tags: ["raspberry-pi", "kubernetes", "homelab", "fedora", "ubuntu", "kali", "workstation-pro", "virtualbox", "virt-manager"],
    slug: null,
  },
  {
    title: "sudo make homelab secure",
    subtitle: "WireGuard, SSH hardening, and zero exposed ports",
    status: "planned",
    tags: ["wireguard", "cybersecurity", "linux", "networking", "netbird", "openziti", "ansible", "opentofu", "packer"],
    slug: null,
  },
  {
    title: "sudo make vibe --toolkit",
    subtitle: "The AI-assisted workflow that actually ships to production",
    status: "planned",
    tags: ["vibecoding", "ai", "cursor", "copilot", "claude", "ollama", "deepseek", "chatgpt", "grok", "kimi", "instructlab"],
    slug: null,
  },
  {
    title: "sudo make homelab ai",
    subtitle: "Running local LLMs — inference, fine-tuning, and RAG without the cloud",
    status: "planned",
    tags: ["ollama", "instructlab", "raspberry-pi", "ai", "llm", "rag", "open-source"],
    slug: null,
  },
  {
    title: "sudo make homelab observe",
    subtitle: "Monitoring, logging, and alerting — knowing when things break before they do",
    status: "planned",
    tags: ["prometheus", "grafana", "linux", "homelab", "kubernetes", "aiops", "open-source"],
    slug: null,
  },
];

const statusConfig: Record<string, { label: string; dot: string; text: string }> = {
  "active":      { label: "active",      dot: "#3d8ab5", text: "#3d8ab5" },
  "in-progress": { label: "in progress", dot: "#d49436", text: "#d49436" },
  "planned":     { label: "planned",     dot: "#7a9bb5", text: "#7a9bb5" },
};
---

<BaseLayout
  title="sudo make vibe — where the command line meets the creative line"
  description="A working lab documenting what happens when AI-generated ideas meet production systems. Real hardware, real failures, real lessons."
>
  <main class="max-w-5xl mx-auto px-4 py-12">

    <!-- Hero -->
    <div class="mb-16">
      <h1 class="text-4xl font-bold mb-2 font-mono" style="color: var(--accent);">/home</h1>
      <p class="text-lg mb-1 font-mono" style="color: var(--text-secondary);">
        Where the command line meets the creative line.
      </p>
      <p class="mb-1 font-mono" style="color: var(--text-primary);">
        Vibe coding meets systems discipline: real hardware, real failures, real lessons.
      </p>
      <p class="mb-6 font-mono text-sm" style="color: var(--text-secondary);">
        Seen it fail at scale. Building it from scratch to understand why.
      </p>
      <div class="flex gap-4 flex-wrap">
        <a
          href="/blog/manifesto"
          class="cta-btn font-mono text-sm px-4 py-2 rounded-full transition"
          style="border: 1px solid var(--border); color: var(--text-secondary); text-decoration: none;"
        >
          → Read the manifesto
        </a>
        <a
          href="/blog"
          class="cta-btn font-mono text-sm px-4 py-2 rounded-full transition"
          style="border: 1px solid var(--border); color: var(--text-secondary); text-decoration: none;"
        >
          → Browse the blog
        </a>
      </div>
    </div>

    <!-- Latest posts -->
    <div class="mb-16">
      <div class="flex items-baseline justify-between mb-6 pb-2" style="border-bottom: 1px solid var(--border);">
        <span class="font-mono text-sm font-bold" style="color: var(--accent);">$ cat ~/blog --latest</span>
        <a href="/blog" class="font-mono text-xs" style="color: var(--text-secondary); text-decoration: none;">all posts →</a>
      </div>
      <div class="space-y-8">
        {latestPosts.map((post) => (
          <BlogCard
            title={post.data.title}
            description={post.data.description}
            pubDate={post.data.pubDate}
            tags={post.data.tags}
            slug={post.slug}
            readingTime={post.readingTime}
          />
        ))}
      </div>
    </div>

    <!-- Projects -->
    <div class="mb-16">
      <div class="flex items-baseline justify-between mb-6 pb-2" style="border-bottom: 1px solid var(--border);">
        <span class="font-mono text-sm font-bold" style="color: var(--accent);">$ ls ~/projects</span>
        <a href="/projects" class="font-mono text-xs" style="color: var(--text-secondary); text-decoration: none;">all projects →</a>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4">
        {projects.map((project) => {
          const status = statusConfig[project.status];
          return (
            <div
              class="rounded-lg p-5 flex flex-col"
              style="background-color: var(--bg-card); border: 1px solid var(--border);"
            >
              <div class="flex items-center gap-2 mb-3">
                <span
                  class="inline-block w-2 h-2 rounded-full"
                  style={`background-color: ${status.dot};`}
                ></span>
                <span class="text-xs font-mono" style={`color: ${status.text};`}>
                  {status.label}
                </span>
              </div>
              <h2 class="text-sm font-bold font-mono mb-1" style="color: var(--accent);">
                {project.title}
              </h2>
              <p class="text-xs mb-3 flex-grow font-mono" style="color: var(--text-secondary); line-height: 1.5;">
                {project.subtitle}
              </p>
              <div class="flex flex-wrap gap-1 mb-3">
                {project.tags.slice(0, 4).map((tag) => (
                  <a
                    href={`/tags/${tag}`}
                    class="text-xs font-mono px-2 py-0.5 rounded"
                    style="background-color: var(--bg-secondary); color: var(--text-secondary); text-decoration: none; border: 1px solid var(--border);"
                  >
                    #{tag}
                  </a>
                ))}
                {project.tags.length > 4 && (
                  <span class="text-xs font-mono" style="color: var(--text-secondary);">
                    +{project.tags.length - 4} more
                  </span>
                )}
              </div>
              {project.slug ? (
                <a
                  href={`/blog/${project.slug}`}
                  class="text-xs font-mono"
                  style="color: var(--accent); text-decoration: none;"
                >
                  → read the writeup
                </a>
              ) : (
                <span class="text-xs font-mono" style="color: var(--border);">writeup coming</span>
              )}
            </div>
          );
        })}
      </div>
    </div>

    <!-- Newsletter -->
    <div
      class="rounded-lg p-6"
      style="background-color: var(--bg-card); border: 1px solid var(--border);"
    >
      <h2 class="text-lg font-bold font-mono mb-1" style="color: var(--text-primary);">
        sudo get updates
      </h2>
      <p class="text-sm mb-4 font-mono" style="color: var(--text-secondary);">
        New posts, project updates, and the occasional post-mortem.
      </p>
      <NewsletterForm />
    </div>

  </main>
</BaseLayout>

<style>
  .cta-btn:hover {
    border-color: var(--accent) !important;
    color: var(--accent) !important;
  }
</style>
